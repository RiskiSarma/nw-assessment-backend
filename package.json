{
  "name": "nw-assessment-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "@nodewave/prisma-ezfilter": "^0.2.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "hono": "^4.12.26",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "postinstall": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev --name init",
    "db:seed": "bun prisma/seed.ts",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "db:deploy": "bunx prisma migrate deploy"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  }
}
